# Dev mode — Vite env vars (baked at build time, used when /config.json is absent)
VITE_WIP_HOST=http://localhost:8001
VITE_WIP_API_KEY=wip-dev-key-001
VITE_BASE_PATH=/

# Container mode — read by docker-entrypoint.sh to generate /config.json at startup
# WIP_API_URL=http://wip-registry:8001
# WIP_API_KEY=wip-dev-key-001
# APP_BASE_PATH=/apps/statements
